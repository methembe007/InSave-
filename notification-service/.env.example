# Server Configuration
PORT=8086

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=insavein
DB_PASSWORD=your_password_here
DB_NAME=insavein
DB_SSLMODE=disable

# JWT Configuration
