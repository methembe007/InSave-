# Server Configuration
PORT=8086

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=insavein_user
DB_PASSWORD=insavein_password
DB_NAME=insavein
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# Email Provider Configuration
EMAIL_PROVIDER=mock  # Options: mock, sendgrid, aws_ses
EMAIL_API_KEY=your_email_api_key_here
EMAIL_FROM_ADDRESS=noreply@insavein.com

# Push Notification Provider Configuration
PUSH_PROVIDER=mock  # Options: mock, fcm
FCM_SERVER_KEY=your_fcm_server_key_here
FCM_PROJECT_ID=your_fcm_project_id_here